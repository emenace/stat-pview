# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (Used in production for CORS)
FRONTEND_URL=https://your-production-domain.com

# Session Configuration
SESSION_SECRET=stat_public_view_secret_key_2026

# Database Configuration (Optional: default is stat-pview.sqlite or stat-pview-dummy.sqlite)
# DB_FILE=stat-pview.sqlite

# Root Superuser Configuration (Cannot be deleted or demoted)
ROOT_PASSWORD=pwdSTAT@123

# Default Administrator Account (Seeded if users table is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Default Standard User Account (Seeded if users table is empty)
USER_USERNAME=user
USER_PASSWORD=user123
